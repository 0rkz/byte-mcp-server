{
  "name": "byte-mcp-server",
  "version": "0.11.11",
  "description": "MCP server for PayPerByte \u2014 cryptographically attested, provenance-verifiable data feeds for AI agents (proves which publisher signed the exact bytes, not data correctness). Pay-per-call via x402 settled in USDC on Base mainnet, or subscribe to first-party on-chain streams (Arbitrum Sepolia, audit-gated); every payload carries an EIP-712 PayloadAttestation receipt. No API keys, no token.",
  "mcpName": "io.github.0rkz/byte-protocol",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "byte-mcp": "dist/index.js"
  },
  "homepage": "https://www.payperbyte.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0rkz/byte-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/0rkz/byte-mcp-server/issues"
  },
  "author": "0rkz (https://github.com/0rkz)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "byte-protocol",
    "payperbyte",
    "byte-library",
    "data-marketplace",
    "ai-agents",
    "x402",
    "x402-mcp",
    "agent-commerce",
    "base",
    "usdc",
    "arbitrum",
    "eip-712",
    "provenance",
    "oracle",
    "depin"
  ],
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE",
    "smithery.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node test/e2e.mjs",
    "prepublishOnly": "npm run build",
    "probe:buy": "npm run build && node probe/buy.mjs",
    "probe:dry": "npm run build && node probe/buy.mjs --dry-run",
    "probe:duck": "node probe/duck.mjs",
    "probe": "npm run build && node probe/pipeline.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^5.0.6",
    "@x402/core": "2.13.0",
    "@x402/evm": "2.13.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "viem": "^2.21.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "hono": "^4.12.22",
    "ip-address": "^10.2.0",
    "qs": "^6.15.2",
    "@x402/core": "2.13.0"
  },
  "pnpm": {
    "overrides": {
      "@x402/core": "2.13.0"
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
