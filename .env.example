# Private key for write operations (subscribe, publish, register, faucet).
# Optional -- without it, only read-only tools are available.
# PRIVATE_KEY=0x...

# Arbitrum Sepolia RPC endpoint (default shown below).
# RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Byte Protocol indexer API URL (default shown below).
# INDEXER_URL=http://localhost:8080
